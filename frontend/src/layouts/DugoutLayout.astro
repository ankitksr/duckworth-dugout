---
interface Props {
  title?: string;
}

const { title = "Duckworth Dugout · IPL Monitor" } = Astro.props;
import "../styles/dugout.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Real-time IPL monitor — live standings, cap races, match intel, and AI-powered tactical briefings on a single screen." />
    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Duckworth Dugout" />
    <meta property="og:title" content="Duckworth Dugout · IPL Monitor" />
    <meta property="og:description" content="Real-time IPL monitor — live standings, cap races, match intel, and AI-powered tactical briefings on a single screen." />
    <meta property="og:url" content="https://duckworth-dugout.pages.dev/" />
    <meta property="og:image" content="https://duckworth-dugout.pages.dev/og-image.jpg" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Duckworth Dugout dashboard — IPL war room with standings, cap race, pulse, and briefing" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Duckworth Dugout · IPL Monitor" />
    <meta name="twitter:description" content="Real-time IPL monitor — live standings, cap races, match intel, and AI-powered tactical briefings on a single screen." />
    <meta name="twitter:image" content="https://duckworth-dugout.pages.dev/og-image.jpg" />
    <meta name="twitter:image:alt" content="Duckworth Dugout dashboard — IPL war room with standings, cap race, pulse, and briefing" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anybody:wght@400;600;900&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
