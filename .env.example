# Required: Gemini API key for LLM intelligence panels
# CT_LLM_API_KEY=

# Optional: use Vertex AI instead of AI Studio
# CT_LLM_VERTEX=true
# CT_LLM_GCP_PROJECT=your-gcp-project
# CT_LLM_GCP_LOCATION=us-central1

# Optional: override model names (defaults: gemini-2.5-flash, gemini-3-pro-preview)
# CT_LLM_MODEL=gemini-2.5-flash
# CT_LLM_MODEL_PRO=gemini-3-pro-preview

# Optional: rate limit for LLM calls (default: 10 requests/min)
# CT_LLM_RATE_LIMIT_RPM=10

# Optional: path to cricket.duckdb (default: data/cricket.duckdb)
# CRICKET_DB_PATH=data/cricket.duckdb
